{
  "name": "s3rp3nt",
  "version": "1.0.20",
  "main": "main.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "electron .",
    "build": "electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "keywords": [],
  "author": "Motan",
  "license": "ISC",
  "description": "An Electron app with auto-update functionality",
  "dependencies": {
    "electron-updater": "^5.3.0"
  },
  "devDependencies": {
    "electron-builder": "^23.6.0",
    "electron": "33.2.1"
  },
  "build": {
    "appId": "com.motan.s3rp3nt",
    "productName": "s3rp3nt",
    "directories": {
      "output": "release-builds"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "path/to/your/icon.ico"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "MotanOfficial",
        "repo": "s3rp3nt",
        "token": "${env.GH_TOKEN}"
      }
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/MotanOfficial/s3rp3nt.git"
}
}